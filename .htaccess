Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct web access to application internals.
    RewriteRule ^(bin|config|migrations|src|templates|tests|translations|var|vendor)(/|$) - [F,L]
    RewriteRule ^(\.env|\.env\..*|composer\.(json|lock)|composer\.phar|package\.json|phpunit\.xml\.dist|symfony\.lock|webpack\.config\.js|yarn\.lock|demo_seed\.sql)$ - [F,L]

    # Serve existing files directly, route everything else through Symfony.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.php [L]
</IfModule>
