<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>
            {% block title %}Astrasneaker | Vos sneakers EzPz{% endblock %}
        </title>
        <link rel="icon" href="icons/favicon.ico">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-0evHe/X+R7YkIZDRvuzKMRqM+OrBnVFBL6DOitfPri4tjfHxaWutUpFmBp4vmVor" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.3/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/styles/app.css">
        <style>
            body {
                min-height: 100vh;
                width: 100%;
            }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="d-flex flex-column">
        <header class="site-header sticky-top">
            <div class="site-header__bar">
                <div class="container py-2">
                    <div class="row g-3 align-items-center site-header__top">
                        <div class="col-12 col-lg-4 order-1 text-center text-lg-start">
                            <a class="site-header__logo text-white text-decoration-none" href="{{ path('homepage') }}">
                                <span class="fw-bold site-header__brand">AstralSneaker</span>
                            </a>
                        </div>
                        <div class="col-12 col-lg-4 order-2">
                            <form method="get" action="{{ path('productslist') }}">
                                <div class="row g-2 align-items-center site-header__search-tools">
                                    <div class="col-8">
                                        <input class="form-control form-control-sm" type="text" name="name_search" placeholder="Chercher un produit" value="" aria-label="Chercher un produit">
                                    </div>
                                    <div class="col-2">
                                        <button type="submit" class="btn btn-danger btn-sm w-100" aria-label="Rechercher">
                                            <i class="bi bi-search"></i>
                                        </button>
                                    </div>
                                    <div class="col-2">
                                        <a href="{{ path('cart_index') }}" class="btn btn-danger btn-sm w-100 site-header__cart-btn" aria-label="Panier">
                                            <i class="bi bi-cart-fill"></i>
                                        </a>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="col-12 col-lg-4 order-3">
                            <div class="site-header__actions">
                                {% if is_granted('ROLE_USER') %}
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-sm btn-danger dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                            Mon compte
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item" href="{{ path('update_user') }}">Mes informations</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="{{ path('userorder') }}">Mes commandes</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="{{ path('app_logout') }}">Deconnexion</a>
                                            </li>
                                        </ul>
                                    </div>
                                {% else %}
                                    <a class="btn btn-danger btn-sm fw-bold" href="{{ path('app_login') }}">Se connecter</a>
                                {% endif %}
                                {% if is_granted('ROLE_ADMIN') %}
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-sm btn-danger dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                            Administration
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item" href="{{ path('order') }}">Commandes</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="{{ path('product_add') }}">Ajouter produit</a>
                                            </li>
                                        </ul>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <nav class="navbar navbar-expand-lg navbar-dark bg-dark site-header__nav-wrap">
                <div class="container site-header__nav">
                    <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Ouvrir le menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse justify-content-center" id="navbarNavDropdown">
                        <ul class="navbar-nav site-header__nav-list">
                            <li class="nav-item">
                                <a class="nav-link" aria-current="page" href="{{ path('homepage') }}">Accueil</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('productslist') }}">Nos produits</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('contact') }}">Contactez-nous</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container flex-grow-1 my-4">
            {% block body %}{% endblock %}
        </div>

        <footer class="footer container-fluid bg-primary m-0 py-5">
            <div class="container">
                <div class="row g-4 m-auto">
                    <ul class="col-12 col-md-4 list-unstyled d-flex flex-column justify-content-center align-items-center text-center m-auto my-2 footer__list">
                        <li class="m-0">
                            <a href="{{ path('homepage') }}">Accueil</a>
                        </li>
                        <li class="m-0">
                            <a href="{{ path('productslist') }}">Nos produits</a>
                        </li>
                        <li class="m-0">
                            <a href="{{ path('contact') }}">Contactez-nous</a>
                        </li>
                        {% if is_granted('ROLE_USER') %}
                            <li class="m-0">
                                <a href="{{ path('update_user') }}">Mon compte</a>
                            </li>
                        {% endif %}
                    </ul>

                    <ul class="col-12 col-md-4 list-unstyled d-flex flex-column justify-content-center align-items-center text-center my-2 footer__list">
                        <li class="m-0">
                            <a href="#">Mentions Legales</a>
                        </li>
                        <li class="m-0">
                            <a href="#">Politique de confidentialite</a>
                        </li>
                        <li class="m-0">
                            <a href="#">CGV</a>
                        </li>
                        <li class="m-0">
                            <a href="#">CGU</a>
                        </li>
                    </ul>

                    <div class="col-12 col-md-4 d-flex justify-content-center align-items-center flex-wrap my-2 footer__socials">
                        <a href="#" class="icons mx-1">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="#" class="icons mx-1">
                            <i class="bi bi-linkedin"></i>
                        </a>
                        <a href="#" class="icons mx-1">
                            <i class="bi bi-twitter"></i>
                        </a>
                        <a href="#" class="icons mx-1">
                            <i class="bi bi-facebook"></i>
                        </a>
                    </div>
                </div>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/js/bootstrap.bundle.min.js" integrity="sha384-pprn3073KE6tl6bjs2QrFaJGz5/SUsLqktiwsUTF55Jfv3qYSDhgCecCxMW52nD2" crossorigin="anonymous"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
